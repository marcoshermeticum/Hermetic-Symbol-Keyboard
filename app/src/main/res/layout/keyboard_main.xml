<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Suggestion bar -->
    <LinearLayout
        android:id="@+id/suggestion_bar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/suggestion_bar"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/suggestion_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/suggestion_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/suggestion_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/on_background"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Keyboard rows container -->
    <LinearLayout
        android:id="@+id/keyboard_rows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- Row 1: Q W E R T Y U I O P -->
        <include layout="@layout/keyboard_row_qwerty" />

    </LinearLayout>

</LinearLayout>
